# API Configuration
APP_NAME=PulseCore
# Deployment environment — sent as required field in every log to VitalTrace.
# Values: development | staging | production
ENVIRONMENT=development
DEBUG=False

# CORS
ALLOWED_ORIGINS=*
ALLOWED_METHODS=*
ALLOWED_HEADERS=*

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password-de-16-caracteres
SMTP_FROM_EMAIL=tu-email@gmail.com
SMTP_USE_TLS=True
SMTP_STARTTLS=True

# Branding — used in email templates
COMPANY_NAME=Digital Hospital
COMPANY_LOGO_URL=
SUPPORT_EMAIL=soporte@example.com
WEBSITE_URL=https://example.com

# Service URLs
# URL of the VitalTrace observability service (app_logger_tracer)
SERVICE_LOGGER_TRACER_URL=http://localhost:8010
